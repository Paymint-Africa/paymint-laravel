{
    "name": "paymint/paymint-laravel",
    "description": "The official Laravel wrapper for PayMint Africa",
    "type": "library",
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "paymint/paymint-php": "*@dev"
    },
    "autoload": {
        "psr-4": {
            "PayMint\\Laravel\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PayMint\\Laravel\\PayMintServiceProvider"
            ],
            "aliases": {
                "PayMint": "PayMint\\Laravel\\Facades\\PayMint"
            }
        }
    }
}
